# Copiar a .env y completar según el entorno

# Perfil activo (h2, mysql, render, prod)
SPRING_PROFILES_ACTIVE=h2

# Base de datos MySQL (solo para perfil mysql/prod)
MYSQL_ROOT_PASSWORD=changeme
MYSQL_DATABASE=tarrobuild
MYSQL_USER=tarrobuild
MYSQL_PASSWORD=changeme
MYSQL_HOST=localhost
MYSQL_PORT=3306

# Base de datos PostgreSQL (solo para perfil render)
POSTGRES_USER=tarrobuild
POSTGRES_PASSWORD=changeme
POSTGRES_DB=tarrobuild
DATABASE_URL=

# Puertos de servicios (opcional, default por servicio)
SERVER_PORT=

# URLs de servicios para comunicación interna
AUTH_SERVICE_URL=http://localhost:8081
USER_SERVICE_URL=http://localhost:8082
PRODUCT_SERVICE_URL=http://localhost:8083
CATEGORY_SERVICE_URL=http://localhost:8084
COMPATIBILITY_SERVICE_URL=http://localhost:8085
PROVIDER_SERVICE_URL=http://localhost:8086
BUILD_SERVICE_URL=http://localhost:8087
ESTIMATE_SERVICE_URL=http://localhost:8088
HARDWARE_ADVISOR_SERVICE_URL=http://localhost:8089
NOTIFICATION_SERVICE_URL=http://localhost:8090

# JWT
JWT_SECRET=
JWT_EXPIRATION=86400000

# Springdoc
SPRINGDOC_SWAGGER_UI_PATH=/swagger-ui.html

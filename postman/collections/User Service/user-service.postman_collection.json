{
  "info": {
    "name": "User Service",
    "description": "# User Service\n\nBase URL: `{{user_service}}{{api_prefix}}`\n\nManages application users. Supports CRUD operations plus search by name, email, and phone, including error/edge-case scenarios.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Direct",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "host": [
                "{{user_service}}{{api_prefix}}"
              ],
              "raw": "{{user_service}}{{api_prefix}}/users",
              "path": [
                "users"
              ]
            },
            "description": "Retrieves all users in the system."
          }
        },
        {
          "name": "Get Users By Name",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "query": [
                {
                  "key": "name",
                  "value": "Lucas"
                }
              ],
              "host": [
                "{{user_service}}{{api_prefix}}"
              ],
              "raw": "{{user_service}}{{api_prefix}}/users?name=Lucas",
              "path": [
                "users"
              ]
            },
            "description": "Searches users by first name. Uses query parameter `name`."
          }
        },
        {
          "name": "Get Users By Name And Last Name",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "query": [
                {
                  "key": "name",
                  "value": "Lucas"
                },
                {
                  "key": "last_name",
                  "value": "Vargas"
                }
              ],
              "host": [
                "{{user_service}}{{api_prefix}}"
              ],
              "raw": "{{user_service}}{{api_prefix}}/users?name=Lucas&last_name=Vargas",
              "path": [
                "users"
              ]
            },
            "description": "Searches users by both first name and last name."
          }
        },
        {
          "name": "Get User By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "host": [
                "{{user_service}}{{api_prefix}}"
              ],

              "path": [
                "users",
                "phone",
                "+56912345678"
              ]
            },
            "description": "Retrieves a user by their phone number. Returns 404 if not found."
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "host": [
                "{{user_service}}{{api_prefix}}"
              ],
              "raw": "{{user_service}}{{api_prefix}}/users",
              "path": [
                "users"
              ]
            },
            "description": "Creates a new user. Required fields: `name`, `lastName`, `email`, `phone`.\n\n**Expected:** 201 Created",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Lucas\",\n  \"lastName\": \"Vargas\",\n  \"email\": \"lucas@tarrobuild.cl\",\n  \"phone\": \"+56912345678\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Create User Duplicate Email",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "host": [
                "{{user_service}}{{api_prefix}}"
              ],
              "raw": "{{user_service}}{{api_prefix}}/users",
              "path": [
                "users"
              ]
            },
            "description": "Negative test -- tries to create a user with an already-registered email.\n\n**Expected:** 409 Conflict (duplicate email)",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Otro\",\n  \"lastName\": \"Usuario\",\n  \"email\": \"lucas@tarrobuild.cl\",\n  \"phone\": \"+56911111111\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Create User Invalid",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "host": [
                "{{user_service}}{{api_prefix}}"
              ],
              "raw": "{{user_service}}{{api_prefix}}/users",
              "path": [
                "users"
              ]
            },
            "description": "Negative test -- sends empty name/lastName, invalid email, and too-short phone.\n\n**Expected:** 400 Bad Request (validation errors)",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"\",\n  \"lastName\": \"\",\n  \"email\": \"notanemail\",\n  \"phone\": \"1\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "host": [
                "{{user_service}}{{api_prefix}}"
              ],
              "raw": "{{user_service}}{{api_prefix}}/users/1",
              "path": [
                "users",
                "1"
              ]
            },
            "description": "Updates an existing user's name and phone. Email is not included (not updatable).\n\n**Expected:** 200 OK",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Lucas Updated\",\n  \"lastName\": \"Vargas\",\n  \"phone\": \"+56999999999\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "host": [
                "{{user_service}}{{api_prefix}}"
              ],
              "raw": "{{user_service}}{{api_prefix}}/users/1",
              "path": [
                "users",
                "1"
              ]
            },
            "description": "Deletes a user by ID.\n\n**Expected:** 204 No Content"
          }
        },
        {
          "name": "Delete User Not Found",

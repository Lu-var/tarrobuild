              "path": [
                "users",
                "email",
                "lucas@tarrobuild.cl"
              ]
            },
            "description": "Retrieves a user by their email address. Returns 404 if not found."
          }
        },
        {
          "name": "Get User By Phone",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "host": [
                "{{user_service}}{{api_prefix}}"
              ],

      "name": "Direct",
      "item": [
        {
          "name": "Generate Recommendations",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "host": [
                "{{hardware_advisor_service}}{{api_prefix}}"
              ],
              "raw": "{{hardware_advisor_service}}{{api_prefix}}/recommendations/generate",
              "path": [
                "recommendations",
                "generate"
              ]
            },
            "description": "Generates hardware recommendations for a user.\n\n**Expected:** 200 OK",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"budget\": 1500000,\n  \"purpose\": \"gaming\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {

              "raw": "{{hardware_advisor_service}}{{api_prefix}}/recommendations/1",
              "path": [
                "recommendations",
                "1"
              ]
            },
            "description": "Retrieves saved recommendations for a user."
          }
        },
        {
          "name": "Get Recommendation History",

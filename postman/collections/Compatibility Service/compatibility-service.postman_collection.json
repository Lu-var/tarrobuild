{
  "info": {
    "name": "Compatibility Service",
    "description": "# Compatibility Service\n\nBase URL: `{{compatibility_service}}{{api_prefix}}`\n\nValidates component compatibility for PC builds.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Direct",
      "item": [
        {
          "name": "Check Compatibility",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "host": [
                "{{compatibility_service}}{{api_prefix}}"
              ],
              "raw": "{{compatibility_service}}{{api_prefix}}/compatibility/check",
              "path": [
                "compatibility",
                "check"
              ]
            },
            "description": "Validates compatibility of a set of products for a build.\n\n**Expected:** 200 OK",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productIds\": [\n    1,\n    2\n  ],\n  \"buildId\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Get Compatibility By Build",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "host": [
                "{{compatibility_service}}{{api_prefix}}"
              ],
              "raw": "{{compatibility_service}}{{api_prefix}}/compatibility/1",
              "path": [
                "compatibility",
                "1"
              ]
            },
            "description": "Retrieves the compatibility result for a specific build."
          }
        },
        {
          "name": "Get Recommendations",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "host": [
                "{{compatibility_service}}{{api_prefix}}"
              ],
              "raw": "{{compatibility_service}}{{api_prefix}}/compatibility/recommendations/1",
              "path": [
                "compatibility",
                "recommendations",
                "1"
              ]
            },
            "description": "Gets recommended compatible components for a build."
          }
        },
        {
          "name": "Check Invalid Products",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "host": [
                "{{compatibility_service}}{{api_prefix}}"
              ],
              "raw": "{{compatibility_service}}{{api_prefix}}/compatibility/check",
              "path": [
                "compatibility",
                "check"
              ]
            },
            "description": "Checks with only one product \u2014 should fail validation.\n\n**Expected:** 400 Bad Request",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productIds\": [\n    1\n  ],\n  \"buildId\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Check Non-existent Build",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "host": [
                "{{compatibility_service}}{{api_prefix}}"
              ],
              "raw": "{{compatibility_service}}{{api_prefix}}/compatibility/check",
              "path": [
                "compatibility",
                "check"
              ]
            },
            "description": "Checks compatibility for a non-existent build.\n\n**Expected:** 404 Not Found",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productIds\": [\n    1,\n    2\n  ],\n  \"buildId\": 9999\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        }
      ]
    },

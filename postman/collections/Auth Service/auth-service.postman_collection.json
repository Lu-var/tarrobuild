                            "mode": "raw",
                            "raw": "{\n  \"email\": \"\",\n  \"password\": \"\",\n  \"name\": \"\",\n  \"lastName\": \"\",\n  \"phone\": \"\"\n}",
                            "options": { "raw": { "language": "json" } }
                        },
                        "url": {
                            "raw": "{{auth_service}}{{api_prefix}}/auth/register",
                            "host": ["{{auth_service}}{{api_prefix}}"],
                            "path": ["auth", "register"]
                        },
                        "description": "Negative test — sends blank required fields.\n\n**Expected:** 400 Bad Request (validation errors)"
                    },
                    "response": []

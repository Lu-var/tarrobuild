{
    "info": {
        "name": "Auth Service",
        "description": "# Auth Service\n\nBase URL: `{{auth_service}}` (port `8081`)\n\nHandles user registration, authentication (JWT), token validation, and logout.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Direct Requests",
            "item": [
                {
                    "name": "Admin Login",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"admin@tarrobuild.cl\",\n  \"password\": \"admin123\"\n}",
                            "options": { "raw": { "language": "json" } }
                        },
                        "url": {
                            "raw": "{{auth_service}}{{api_prefix}}/auth/login",
                            "host": ["{{auth_service}}{{api_prefix}}"],
                            "path": ["auth", "login"]
                        },
                        "description": "Logs in as admin. The admin role is required for product/category/provider/user management endpoints.\n\n**Expected:** 200 OK (returns JWT token)"
                    },
                    "response": []
                },
                {
                    "name": "User Login",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"user@tarrobuild.cl\",\n  \"password\": \"test123\"\n}",
                            "options": { "raw": { "language": "json" } }
                        },
                        "url": {
                            "raw": "{{auth_service}}{{api_prefix}}/auth/login",
                            "host": ["{{auth_service}}{{api_prefix}}"],
                            "path": ["auth", "login"]
                        },
                        "description": "Logs in as a regular USER role. User role can access builds, estimates, recommendations, and notifications.\n\n**Expected:** 200 OK (returns JWT token)"
                    },
                    "response": []
                },
                {
                    "name": "Register",
                    "request": {
                        "auth": { "type": "noauth" },
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"test@tarrobuild.cl\",\n  \"password\": \"TestPass123\",\n  \"name\": \"Test\",\n  \"lastName\": \"User\",\n  \"phone\": \"12345678\"\n}",
                            "options": { "raw": { "language": "json" } }
                        },
                        "url": {
                            "raw": "{{auth_service}}{{api_prefix}}/auth/register",
                            "host": ["{{auth_service}}{{api_prefix}}"],
                            "path": ["auth", "register"]
                        },
                        "description": "Registers a new user. Creates both a Credential (for login) and a User profile (via RestClient to user-service).\n\n**Expected:** 201 Created"
                    },
                    "response": []
                },
                {
                    "name": "Register Duplicate Email",
                    "request": {
                        "auth": { "type": "noauth" },
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"admin@tarrobuild.cl\",\n  \"password\": \"admin123\",\n  \"name\": \"Dup\",\n  \"lastName\": \"Admin\",\n  \"phone\": \"98765432\"\n}",
                            "options": { "raw": { "language": "json" } }
                        },
                        "url": {
                            "raw": "{{auth_service}}{{api_prefix}}/auth/register",
                            "host": ["{{auth_service}}{{api_prefix}}"],
                            "path": ["auth", "register"]
                        },
                        "description": "Negative test — tries to register with an email that already exists.\n\n**Expected:** 409 Conflict"
                    },
                    "response": []
                },
                {
                    "name": "Register Invalid",
                    "request": {
                        "auth": { "type": "noauth" },
                        "method": "POST",

                    "name": "Login Invalid Body",
                    "request": {
                        "auth": { "type": "noauth" },
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{}",
                            "options": { "raw": { "language": "json" } }
                        },
                        "url": {
                            "raw": "{{auth_service}}{{api_prefix}}/auth/login",
                            "host": ["{{auth_service}}{{api_prefix}}"],
                            "path": ["auth", "login"]

                {
                    "name": "Validate Token",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{auth_service}}{{api_prefix}}/auth/validate",
                            "host": ["{{auth_service}}{{api_prefix}}"],
                            "path": ["auth", "validate"]
                        },
                        "description": "Validates a JWT token. Requires a valid Bearer token in the Authorization header.\n\n**Expected:** 200 OK (returns userId, email, role)"
                    },
                    "response": []
                },
                {
                    "name": "Validate No Token",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{auth_service}}{{api_prefix}}/auth/validate",
                            "host": ["{{auth_service}}{{api_prefix}}"],
                            "path": ["auth", "validate"]
                        },
                        "description": "Negative test — calls validate without an Authorization header.\n\n**Expected:** 401 Unauthorized"
                    },
                    "response": []
                },
                {
                    "name": "Validate Invalid Token",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer invalidtoken123",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{auth_service}}{{api_prefix}}/auth/validate",
                            "host": ["{{auth_service}}{{api_prefix}}"],
                            "path": ["auth", "validate"]
                        },
                        "description": "Negative test — passes a malformed/invalid JWT token.\n\n**Expected:** 401 Unauthorized"
                    },
                    "response": []
                },
                {
                    "name": "Logout",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "",
                            "options": { "raw": { "language": "json" } }
                        },
                        "url": {
                            "raw": "{{auth_service}}{{api_prefix}}/auth/logout",
                            "host": ["{{auth_service}}{{api_prefix}}"],
                            "path": ["auth", "logout"]
                        },
                        "description": "Logs out the current session. Note: JWT is stateless so this is a placeholder for future token blacklist logic.\n\n**Expected:** 200 OK"
                    },
                    "response": []
                }
            ]
        },

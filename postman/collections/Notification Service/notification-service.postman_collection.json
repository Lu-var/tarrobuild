              ],
              "raw": "{{notification_service}}{{api_prefix}}/notifications/logs/user/9999",
              "path": [
                "notifications",
                "logs",
                "user",
                "9999"
              ]
            },
            "description": "Negative test -- queries notifications for a user with no logs. Returns an empty array, not a 404.\n\n**Expected:** 200 OK (empty list)"
          }
        },
        {
          "name": "Get Log By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "host": [
                "{{notification_service}}{{api_prefix}}"
              ],
              "raw": "{{notification_service}}{{api_prefix}}/notifications/logs/1",
              "path": [
                "notifications",
                "logs",
                "1"
              ]
            },
            "description": "Retrieves a single notification log by its ID.\n\n**Expected:** 200 OK"
          }
        },
        {
          "name": "Get Log By Id Not Found",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "host": [
                "{{notification_service}}{{api_prefix}}"

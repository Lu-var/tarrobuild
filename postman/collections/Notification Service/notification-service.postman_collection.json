            },
            "description": "Negative test -- sends a request with null userId, blank type/content, and null status.\n\n**Expected:** 400 Bad Request (validation errors)",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": null,\n  \"type\": \"\",\n  \"content\": \"\",\n  \"status\": null\n}",
              "options": {

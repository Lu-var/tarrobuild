              "path": [
                "notifications",
                "logs"
              ]
            },
            "description": "Retrieves all notification logs across all users. Returns an empty array if none exist.\n\n**Expected:** 200 OK"
          }
        },
        {
          "name": "Get Logs By User Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "host": [
                "{{notification_service}}{{api_prefix}}"
              ],
              "raw": "{{notification_service}}{{api_prefix}}/notifications/logs/user/1",
              "path": [
                "notifications",
                "logs",
                "user",
                "1"
              ]
            },
            "description": "Retrieves all notifications for a specific user. Returns an empty array if the user has no notifications.\n\n**Expected:** 200 OK"
          }
        },
        {
          "name": "Get Logs By User Id No Results",
          "request": {
            "method": "GET",
            "header": [],
            "url": {

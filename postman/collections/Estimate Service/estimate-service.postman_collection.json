            },
            "description": "Invalid build through the API Gateway.\n\n**Expected:** 404 Not Found",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"buildId\": 9999,\n  \"currency\": \"CLP\"\n}",
              "options": {

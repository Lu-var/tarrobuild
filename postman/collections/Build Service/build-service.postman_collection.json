{
    "info": {
        "name": "Build Service",
        "description": "# Build Service\n\nBase URL: `{{build_service}}{{api_prefix}}`\n\nManages PC builds and their items. Supports full CRUD for both builds and build items, including error/edge-case scenarios.\n\n## Usage\n\n### Direct Requests\nHit the build-service directly at `{{build_service}}`. All requests require the `X-User-Id` header identifying the authenticated user.\n\n### Proxy Requests (via gateway)\nGo through the API gateway at `{{api_gateway}}`. Requires `Authorization: Bearer <token>`. The gateway injects `X-User-Id` automatically from the JWT.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "admin_token",
            "value": "",
            "type": "string"
        },
        {
            "key": "user_token",
            "value": "",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "Direct Requests",
            "item": [
                {
                    "name": "Get All Builds",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "X-User-Id",
                                "value": "1",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "host": [
                                "{{build_service}}{{api_prefix}}"
                            ],
                            "raw": "{{build_service}}{{api_prefix}}/builds",
                            "path": [
                                "builds"
                            ]
                        },
                        "description": "Retrieves all builds in the system. No filters or pagination applied.\n\nRequires `X-User-Id` header identifying the authenticated user."
                    }
                },
                {
                    "name": "Get Build By Id",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "X-User-Id",
                                "value": "1",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "host": [
                                "{{build_service}}{{api_prefix}}"
                            ],
                            "raw": "{{build_service}}{{api_prefix}}/builds/1",
                            "path": [
                                "builds",
                                "1"
                            ]
                        },
                        "description": "Retrieves a single build by its ID. Returns 404 if not found.\n\nRequires `X-User-Id` header identifying the authenticated user."
                    }
                },
                {
                    "name": "Get Builds By User Id",
                    "request": {
                        "method": "GET",
                        "header": [
